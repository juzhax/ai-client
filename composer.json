{
    "name": "juzhax/ai-client",
    "description": "Framework-independent PHP SDK for the Justin AI Platform REST API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "guzzlehttp/psr7": "^2.7",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {"Juzhax\\AiClient\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Juzhax\\AiClient\\Tests\\": "tests/"}
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
